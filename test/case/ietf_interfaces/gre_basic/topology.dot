graph "gre-basic" {
	layout="neato";
	overlap="false";
	esep="+40";

        node [shape=record, fontname="DejaVu Sans Mono, Book"];
	edge [color="cornflowerblue", penwidth="2", fontname="DejaVu Serif, Book"];

	host [
	    label="host | { <mgmt1> mgmt1 | <mgmt2> mgmt2 | <data> data }"
	    pos="0,15!",
	    kind="controller",
	];

        left [
	    label="{ <mgmt> mgmt | <data> data  } | { \n left \n\n |  <link> link }",
	    pos="10,18!",

	    kind="infix",
	];

        right [
		label="{ <mgmt> mgmt } | { <link> link | \n right \n\n }",
	    pos="10,12!",

	    kind="infix",
	];

	host:mgmt1 -- left:mgmt [kind=mgmt]
	host:data -- left:data [color=black]

	host:mgmt2 -- right:mgmt [kind=mgmt]


	left:link -- right:link [color=black]
}