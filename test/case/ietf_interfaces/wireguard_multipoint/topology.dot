graph "wireguard-multipoint" {
	layout="neato";
	overlap="false";
	esep="+40";

        node [shape=record, fontname="DejaVu Sans Mono, Book"];
	edge [color="cornflowerblue", penwidth="2", fontname="DejaVu Serif, Book"];

	host [
	    label="host | { <mgmt1> mgmt1 } | { <data> data } | { <mgmt2> mgmt2 } | { <mgmt3> mgmt3 } | { <mgmt4> mgmt4 }"
	    pos="6,0!",
	    requires="controller",
	];

        server [
	    label="{ server } | { <mgmt> mgmt } | { <link1> link1 } | { <link2> link2 } | { <link3> link3 }",
	    pos="6, -6!",
	    requires="infix",
	];

        client1 [
	    label="{ <link> link } | { <data> data } | { <mgmt> mgmt } |  { client1 }",
	    pos="0, -6!",
	    requires="infix",
	];

        client2 [
	    label="{ <link> link } | { <mgmt> mgmt } |  { client2 }",
	    pos="6,-12!",
	    requires="infix",
	];

        client3 [
	    label="{ <link> link } | { <mgmt> mgmt } |  { client3 }",
	    pos="12,-6!",
	    requires="infix",
	];

	host:mgmt1 -- server:mgmt [requires="mgmt", color="lightgray"]
	host:mgmt2 -- client1:mgmt [requires="mgmt", color="lightgray"]
	host:mgmt3 -- client2:mgmt [requires="mgmt", color="lightgray"]
	host:mgmt4 -- client3:mgmt [requires="mgmt", color="lightgray"]

	host:data -- client1:data [headlabel=".1", label="192.168.10.0/24" taillabel=".2&nbsp;", labeldistance=1, fontcolor="black", color="black"]

	server:link1 -- client1:link [headlabel=".1", label="192.168.50.0/24", taillabel=".10&nbsp;", labeldistance=1, fontcolor="black", color="black"]
	server:link2 -- client2:link [headlabel=".2\n\n", label="192.168.60.0/24", taillabel="\n.20", labeldistance=1, fontcolor="black", color="black"]
	server:link3 -- client3:link [headlabel=".3&nbsp;", label="192.168.70.0/24", taillabel=".30", labeldistance=1, fontcolor="black", color="black"]
}
