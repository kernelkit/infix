diff -urN dnsmasq-2.90.org/src/rfc2131.c dnsmasq-2.90/src/rfc2131.c
--- dnsmasq-2.90.org/src/rfc2131.c	2024-02-13 14:49:15.000000000 +0100
+++ dnsmasq-2.90/src/rfc2131.c	2025-03-04 09:45:24.652581206 +0100
@@ -2812,4 +2812,130 @@
     }
